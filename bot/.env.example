# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# OpenAI
OPENAI_API_KEY=sk-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Company defaults (UUIDs deben coincidir con los datos de Supabase)
DEFAULT_SELLER_COMPANY_ID=11111111-1111-1111-1111-111111111111
DEFAULT_SELLER_COMPANY_NAME=Demo Company

# Fathom webhook integration
# Obtener desde Fathom Settings → API Access → Webhooks
# Formato SVix: puede ser raw string o "whsec_<base64>"
FATHOM_WEBHOOK_SECRET=whsec_...

# Puerto HTTP para webhooks entrantes (Railway inyecta PORT automáticamente)
PORT=8080
