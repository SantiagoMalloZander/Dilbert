# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=https://dilvert.netlify.app/app/api/auth
DILBERT_APP_LOGIN_URL=https://dilvert.netlify.app/app/

# ── Supabase ──────────────────────────────────────────────────────────────────
# Solo estas dos variables pueden exponerse al browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Solo server-side. Nunca exponer al cliente.
SUPABASE_SERVICE_KEY=service-role-key-server-only

# ── Resend (emails de confirmación) ───────────────────────────────────────────
# 1. Crear cuenta gratis en resend.com
# 2. Settings → API Keys → Create API Key → copiar acá
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sin dominio verificado, usar: "onboarding@resend.dev" (funciona en modo test)
# Con dominio propio verificado: "Dilbert <demos@tudominio.com>"
RESEND_FROM_EMAIL=Dilbert <onboarding@resend.dev>
# Email del equipo que recibe la notificación de cada demo agendada
TEAM_NOTIFICATION_EMAIL=equipo@tuempresa.com

# ── OAuth opcional para /app/ ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=telegram-bot-token-server-only
