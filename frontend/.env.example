# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=dilbert-hackitba-secret-2026

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Google Calendar (Service Account) ─────────────────────────────────────────
# Ver SETUP_GCAL.md para instrucciones de configuración
GOOGLE_SERVICE_ACCOUNT_EMAIL=dilbert-demo@your-project.iam.gserviceaccount.com
# Pegar la private_key del JSON de la service account (con \n literales)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
# ID del calendario donde crear los eventos (ej: tu email o el ID del cal de demos)
GOOGLE_CALENDAR_ID=demos@tuempresa.com

# ── Resend (emails de confirmación) ───────────────────────────────────────────
# Crear cuenta en resend.com, verificar dominio, obtener API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# El "from" debe usar un dominio verificado en Resend
RESEND_FROM_EMAIL=Dilbert <demos@tudominio.com>
# Email del equipo que recibe la notificación de cada demo agendada
TEAM_NOTIFICATION_EMAIL=equipo@tuempresa.com

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8635428885:AAF...
